## TODO: for everybody who wants to help with code implementation .asset files
## choose between 3 different shaders: 
## 1. standard 
## 2. standard_usercolor_alpha 
## 3. standard_usercolor_coa
##
## USE this shader for:
##
## shader = "standard"
## eyes + skin (like head or other human skin parts)
## example:
#
#	meshsettings = {
#		name = "acg_dwarf_eyes_1"
#		index = 0
#		texture_diffuse = "acg_dwarf_eyes_1_diffuse.dds"
#		texture_normal = "acg_dwarf_eyes_1_normal.dds"
#		texture_specular = "acg_dwarf_eyes_1_properties.dds"
#		shader = "standard"
#		shader_file = "gfx/FX/pdxmesh.shader"
#        additional_shader_defines = {
#            "MAP_LIGHTING_HACK"
#        }
#	}
#
## shader = "standard_usercolor_alpha"
## beards + hair where you see diffuse has invisible parts included
## example:
#
#	meshsettings = {
#		name = "acg_erebor_t2_beard_2"
#		index = 0
#		texture_diffuse = "acg_dwarf_hair_1_diffuse.dds"
#		texture_normal = "acg_dwarf_hair_1_normal.dds"
#		texture_specular = "acg_dwarf_hair_1_properties"
#		shader = "standard_usercolor_alpha"
#		shader_file = "gfx/FX/pdxmesh.shader"
#        additional_shader_defines = {
#            "MAP_LIGHTING_HACK"
#        }
#	}
#
## shader = "standard_usercolor_coa"
## for all other parts (this will most of the time be used)
## example:
#
#	meshsettings = {
#		name = "acg_erebor_t1_pants_2"
#		index = 0
#		texture_diffuse = "acg_erebor_t1_pants_2_diffuse.dds"
