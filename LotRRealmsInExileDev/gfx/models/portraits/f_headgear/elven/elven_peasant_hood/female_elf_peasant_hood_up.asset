pdxmesh = {
	name = "female_elf_peasant_hood_up_mesh"
	file = "female_elf_peasant_hood_up.mesh"

	meshsettings = {
		name = "female_elf_peasant_hood_upShape"
		index = 0
		texture_diffuse = "naerys_hood_diffuse.dds"
		texture_normal = "naerys_hood_normal.dds"
		texture_specular = "naerys_hood_properties.dds"
		shader = "portrait_attachment_pattern"
		shader_file = "gfx/FX/jomini/portrait.shader"
	}
	
	meshsettings = {
		name = "female_elf_hair_under_hoodShape"
		index = 0
		texture_diffuse = "f_hair_indian_03_diffuse.dds"
		texture_normal = "f_hair_indian_03_normal.dds"
		texture_specular = "f_hair_indian_03_properties.dds"
		texture = { file = "black_ssao_color.dds" index = 3 }		
		shader = "portrait_hair"
		shader_file = "gfx/FX/jomini/portrait.shader"
	}
}

#Default Hood Version
entity = {
	name = "female_elf_peasant_hood_up_entity"
	pdxmesh = "female_elf_peasant_hood_up_mesh"
	
	game_data = {
        portrait_entity_user_data = {
			portrait_accessory = {
				pattern_mask = "gfx/models/portraits/m_headgear/elven/elven_peasant_hood/naerys_hood_masks.dds"    #Any 4-channel texture. Each channel will be used to mask a pattern from the variation object
				variation = "elf_peasant_top"	#A "variation" object in gfx/portraits/accessory_variations/
			}
        }
	}
}

