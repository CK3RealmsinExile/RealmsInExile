pdxmesh = {
	name = "female_headgear_secular_northern_common_01_mesh"
	file = "f_headgear_secular_norse_com_01.mesh"

	meshsettings = {
		name = "female_headgear_secular_northern_common_01Shape"
		index = 0
		texture_diffuse = "f_headgear_secular_norse_com_01_diffuse.dds"
		texture_normal = "f_headgear_secular_norse_com_01_normal.dds"
		texture_specular = "f_headgear_secular_norse_com_01_properties.dds"
		shader = "portrait_attachment_pattern"
		shader_file = "gfx/FX/jomini/portrait.shader"
	}
}

entity = {
	name = "female_headgear_secular_northern_common_01_entity"
	pdxmesh = "female_headgear_secular_northern_common_01_mesh"
	

	game_data = {
        portrait_entity_user_data = {
			portrait_accessory = {
				pattern_mask = "gfx/models/portraits/f_headgear/norse/com_01/f_headgear_secular_norse_com_01_masks.dds"	#Any 4-channel texture. Each channel will be used to mask a pattern from the variation object
				variation = "northern_low_01"	#A "variation" object in gfx/portraits/accessory_variations/
			}
        }
	}
	
}

