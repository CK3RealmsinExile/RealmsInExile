### ENTITIES ####
entity = { # COM
	name = "m_headgear_sec_ccp4_khanty_war_com_01_entity"
	pdxmesh = "m_headgear_sec_ccp4_khanty_war_com_01_mesh"

	attribute = { name = "bs_fat_1" 			blend_shape = "m_headgear_sec_ccp4_khanty_war_com_01_bs_fat" }
	attribute = { name = "bs_gaunt_1"					blend_shape = "m_headgear_sec_ccp4_khanty_war_com_01_bs_gaunt" }
	attribute = { name = "bs_old_1"				blend_shape = "m_headgear_sec_ccp4_khanty_war_com_01_bs_old" }	

	game_data = {
        portrait_entity_user_data = {
			portrait_accessory = {
				pattern_mask = "gfx/models/portraits/m_headgear/ccp4_khanty/war_com_01/m_headgear_sec_ccp4_khanty_war_com_01_masks.dds"	#Any 4-channel texture. Each channel will be used to mask a pattern from the variation object
				variation = "ccp4_khanty_war_com_01"	#A "variation" object in gfx/portraits/accessory_variations/
			}
        }
	}
}
