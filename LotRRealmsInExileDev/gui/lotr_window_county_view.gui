											warning_icon = {
												name = "wrong_type"
												datacontext = "[HoldingView.GetHolder]"
												visible = "[And( Not( Holding.IsEmpty ), Not( Holding.IsValidForLesseeOrHolder ) )]"
												size = { 20 20 }

												tooltip = HOLDING_VIEW_WRONG_HOLDING_TYPE
											}

											warning_icon = {
												name = "reduced_by_fixable_situation"
