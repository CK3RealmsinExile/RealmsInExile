template domain_holdings_limit
{
	container = {
		alwaystransparent = no

		object_tooltip_pop_out = {
			blockoverride "title_text" {
				margin = { 0 15 }
				text = "domain_holdings_limit_header"
				default_format = "#T"
			}

			blockoverride "subtitle_text" {
				text = "domain_holdings_limit_desc"
				margin_bottom = -20
			}

			blockoverride "description_text" { }
			blockoverride "concept_link" { }
		}
	}
}

template lotr_elven_character_window_situation_fading_tooltip {
	tooltipwidget = {
		object_tooltip_pop_out = {
			blockoverride "title_text" {
				text = "situation_elven_fading"
			}

			blockoverride "concept_link" {
				text = [situation_sub_region|E]
			}

			blockoverride "description_text" {
				text = "situation_elven_fading_desc"
			}
		}
	}
}

