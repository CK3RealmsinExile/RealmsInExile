template lotr_elven_situation_tooltip {
	container = {
		alwaystransparent = no
		block "datacontext" {}

		object_tooltip_pop_out = {
			blockoverride "header_additions"
			{
				hbox = {
					margin_right = 10
					margin_top = 8
					margin_left = -4

					icon = {
						size = { 52 52 }
						texture = "[Situation.GetCharacterCurrentPhase( GetPlayer.Self ).GetType.GetIcon]"
					}
				}
			}

			blockoverride "title_text" {
				margin = { 0 5 }
				text = "[Situation.GetCharacterCurrentPhase( GetPlayer.Self ).GetType.GetNameNoTooltip]"
				default_format = "#T"
			}

			blockoverride "main_description" {
				vbox = {
					name = "current_phase_information"
					datacontext = "[Situation.GetCharacterCurrentPhase( GetPlayer.Self )]"
					layoutpolicy_horizontal = expanding

					cooltip_paragraph = {
						visible = "[Situation.GetParticipantGroupByCharacter( GetPlayer.Self ).IsValid]"
						text = "SITUATION_TOOLTIP_INVOLVEMENT"
					}

					cooltip_paragraph = {
						text = "SITUATION_TOOLTIP_CURRENT_PHASE"
					}

					cooltip_paragraph = {
						text = "SITUATION_START_DATE"
					}

					cooltip_paragraph = {
						margin_top = 10
						text = "CLICK_TO_VIEW"
					}

				}
			}

			blockoverride "concept_link" {}
		}
	}
}