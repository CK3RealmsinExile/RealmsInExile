	type AutomatedColonisationTitleCheckboxes = vbox {
		text_single = {
			text = WASTELANDS_AUTOMATION_SETTINGS_TITLES
			margin = { 150 20 }
			fontsize = 24
			background = {
				using = Background_Area_Dark
			}
		}

		hbox = { #Hand out to new *generated* ruler automatically
			layoutpolicy_horizontal = expanding

			spacer = { size = { 15 1 } }

			AutomatedColonisationCheckbox = {
				blockoverride "CheckboxOnClick" {
					onclick = "[GetScriptedGui('lotr_WAC_generated_ruler_settings').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
				}
				blockoverride"tooltip_block" {
					tooltip = "WASTELANDS_AUTOMATION_SETTINGS_TITLES_TT"
					using = tooltip_nw
				}
				blockoverride "CheckboxChecked" {
					checked = "[GetPlayer.MakeScope.Var('WAC_setttings').Story.MakeScope.Var('lotr_WAC_generated_ruler_settings').IsSet]"
				}
				enabled = "[GetScriptedGui('lotr_WAC_generated_ruler_settings').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
			}

			expand = { }

			divider_light = { layoutpolicy_vertical = expanding }

			expand = { }

			text_multi = {
				text = WASTELANDS_AUTOMATION_SETTINGS_GENERATED_RULER
				size = { 380 40 }
			}
		}

		divider_light = { layoutpolicy_horizontal = expanding }

		hbox = { #Hand out to vassal ruler automatically
			layoutpolicy_horizontal = expanding

			spacer = { size = { 15 1 } }

			AutomatedColonisationCheckbox = { 
				blockoverride "CheckboxOnClick" {
					onclick = "[GetScriptedGui('lotr_WAC_vassal_ruler_settings').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
				}
				blockoverride"tooltip_block" {
					tooltip = "WASTELANDS_AUTOMATION_SETTINGS_TITLES_TT"
					using = tooltip_nw
				}
				blockoverride "CheckboxChecked" {
					checked = "[GetPlayer.MakeScope.Var('WAC_setttings').Story.MakeScope.Var('lotr_WAC_vassal_ruler_settings').IsSet]"
				}
				enabled = "[GetScriptedGui('lotr_WAC_vassal_ruler_settings').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
			}

			expand = { }

			divider_light = { layoutpolicy_vertical = expanding }

			expand = { }
			
			text_multi = {
				text = WASTELANDS_AUTOMATION_SETTINGS_VASSAL_RULER
				size = { 380 40 }
			}
		}
	}

	type AutomatedColonisationCheckbox = button_checkbox {
		size = { 42 42 }
		block "CheckboxOnClick" {
			onclick = "[GetScriptedGui('lotr_WAC_building_stockade_settings').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		}
		block "tooltip_block" {
			tooltip = "WASTELANDS_AUTOMATION_SETTINGS_TT"
			using = tooltip_nw
		}
		block "CheckboxChecked" {
			checked = "[GetScriptedGui('lotr_WAC_building_stockade_settings').IsShown(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		}
	}

	type AutomatedColonisationGoldLimit = hbox {
		spacing = 5
		layoutpolicy_horizontal = expanding
		margin = { 18 0 }

		AutomatedColonisationGoldLimitReduce = {}

		expand = {}

		text_multi = {
			text = "WASTELANDS_AUTOMATION_SETTINGS_GOLD_LIMIT"
			max_width = 380
			autoresize = yes
		}

		expand = {}

		AutomatedColonisationGoldLimitIncrease = {}
	}

	type AutomatedColonisationGoldLimitIncrease = button_standard {
		size = { 36 36 }

		onclick = "[GetScriptedGui('lotr_WAC_increase_gold_settings').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		enabled = "[GetScriptedGui('lotr_WAC_increase_gold_settings').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		tooltip = "[GetScriptedGui('lotr_WAC_increase_gold_settings').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		using = tooltip_sw
		
		button_plus = {
			parentanchor = center
			alwaystransparent = yes
			size = { 32 32 }
        }
	}

	type AutomatedColonisationGoldLimitReduce = button_standard {
		size = { 36 36 }

		onclick = "[GetScriptedGui('lotr_WAC_decrease_gold_settings').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		enabled = "[GetScriptedGui('lotr_WAC_decrease_gold_settings').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		tooltip = "[GetScriptedGui('lotr_WAC_decrease_gold_settings').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		using = tooltip_sw

		button_minimize = {
			parentanchor = center
			alwaystransparent = yes
			size = { 32 32 }
        }
	}
}