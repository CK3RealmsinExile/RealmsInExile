	type AutomatedColonisationCheckbox = button_checkbox {
		size = { 42 42 }
		block "CheckboxOnClick" {
			onclick = "[GetScriptedGui('lotr_WAC_building_stockade_settings').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
		}
		tooltip = "WASTELANDS_AUTOMATION_SETTINGS_TT"
		using = tooltip_sw
	}
}