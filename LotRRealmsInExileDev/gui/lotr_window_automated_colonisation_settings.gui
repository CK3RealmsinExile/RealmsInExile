window = {
	name = "lotr_window_automated_colonisation_settings"
	size = { 550 600 }
    layer = confirmation
	parentanchor = center

	visible = "[And( Not( IsPauseMenuShown ), And(Or(Not(IsObserver), And(GetPlayer.IsValid, GetPlayer.IsAlive)), And(IsDefaultGUIMode, GetVariableSystem.Exists( 'automated_colonisation_settings_window' ))))]"

	using = Window_Background
	using = Window_Decoration
	using = Animation_ShowHide_Standard

	state = {
		name = _show
		using = Animation_FadeIn_Quick
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Quick
	}

	vbox = {
		using = Window_Margins
		restrictparent_min = yes
		ignoreinvisible = yes
		allow_outside = yes
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding

		vbox = {
			layoutpolicy_horizontal = expanding
			header_pattern = {
				layoutpolicy_horizontal = expanding

				blockoverride "header_text"
				{
					text = "WASTELANDS_AUTOMATION_SETTINGS_HEADER"
				}

				blockoverride "button_close"
				{
					onclick = "[GetVariableSystem.Clear('automated_colonisation_settings_window')]"
				}
			}
		}

		vbox = {
			allow_outside = yes
			widget = {
				size = { 470 180 }
				background = {
					using = Background_Area_Dark
				}
			}

			hbox = {
				widget = {
					size = { 235 325 }
					background = {
						using = Background_Area_Dark
					}
					
					AutomatedColonisationBuildingCheckboxes = {}
				}

				widget = {
					size = { 235 325 }
					background = {
						using = Background_Area_Dark
					}

					AutomatedColonisationHoldingCheckboxes = {}
				}
			}
		}
	}
}

types AutomatedColonisationSettingsTypes {
	type AutomatedColonisationBuildingCheckboxes = vbox {
		text_single = {
			text = WASTELANDS_AUTOMATION_SETTINGS_BUILDINGS
			margin = { 55 10 }
			fontsize = 20
			background = {
				using = Background_Area_Dark
			}
		}
		
		divider_light = { layoutpolicy_horizontal = expanding }

		expand = {}

		hbox = { #Stockades
			layoutpolicy_horizontal = expanding

			spacer = { size = { 15 1 } }

			AutomatedColonisationCheckbox = {
				blockoverride "CheckboxOnClick" {
					onclick = "[GetScriptedGui('lotr_WAC_building_stockade_settings').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
				}
			}

			expand = {}

			text_single = {
				text = building_stockades_01
			}

			spacer = { size = { 15 1 } }
		}

		expand = {}
		
		divider_light = { layoutpolicy_horizontal = expanding }

		expand = {}

		hbox = { #Trading Outposts
			layoutpolicy_horizontal = expanding

			spacer = { size = { 15 1 } }

			AutomatedColonisationCheckbox = {
