						onclick = "[GetVariableSystem.Set( 'potential_phases', 'true' )]"
						onclick = "[GetVariableSystem.Clear( 'situation_endings' )]"
						visible = "[GetVariableSystem.Exists( 'situation_endings' )]"
					}

					spacer = {
						size = { 12 1 }
					}

					divider_light = {
						layoutpolicy_horizontal = expanding
					}
				}

