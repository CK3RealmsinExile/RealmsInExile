					}

					button_primary = {
						margin = { 12 4 }
						text = "KIN_STRIFE_SEE_ENDINGS_BUTTON"
						onclick = "[GetVariableSystem.Set( 'situation_endings', 'true' )]"
						onclick = "[GetVariableSystem.Clear( 'potential_phases' )]"
