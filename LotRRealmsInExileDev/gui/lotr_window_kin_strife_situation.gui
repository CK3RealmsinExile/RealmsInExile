######################################################
##################### SITUATION ######################
######################################################
window = {
	name = "lotr_window_kin_strife_situation"
	widgetid = "lotr_window_kin_strife_situation"
	datacontext = "[SituationWindow.GetSituation]"
	datacontext = "[GetVariableSystem]"
	datacontext = "[GetPlayer]"
	parentanchor = top|right
	layer = windows_layer
	movable = no
	allow_outside = yes

	using = Window_Size_MainTab

	state = {
		name = on_create
		trigger_on_create = yes
		on_start = "[GetVariableSystem.Set( 'potential_phases', 'true'  )]"
		on_start = "[GetVariableSystem.Clear( 'situation_endings' )]"
		on_start = "[GetVariableSystem.Clear( 'kin_strife_catalyst_window' )]"
	}

	state = {
		name = _show
		using = Animation_FadeIn_Quick
		using = Sound_WindowShow_Standard
		using = Window_Position_MainTab
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Quick
		using = Sound_WindowHide_Standard
		using = Window_Position_MainTab_Hide
	}

	margin_widget = {
		size = { 100% 100% }
		margin = { 0 26 }
		margin_right = 13

		widget = {
			size = { 100% 100% }

			vbox = {
				using = Window_Margins

				datacontext = "[SituationWindow.GetSelectedSubRegion]"
				datacontext = "[SituationSubRegion.GetCurrentPhase]"

				layoutpolicy_vertical = expanding
				layoutpolicy_horizontal = expanding

				vbox = { # Header
					layoutpolicy_horizontal = expanding
					spacing = 6

					header_pattern = {
						layoutpolicy_horizontal = expanding

						blockoverride "header_text"
						{
							text = "SITUATION_KIN_STRIFE_HEADER"
						}

						blockoverride "button_back"
						{
							onclick = "[OpenGameView( 'situations' )]"
						}

						blockoverride "button_close"
						{
							onclick = "[SituationWindow.Close]"
						}
					}
				}

				vbox  = {
					layoutpolicy_horizontal = expanding
					margin_bottom = 42

					# # Reserved space for current
					widget = {
						name = "current_phase_area"
						size = { 560 88 }
					}

					# Leaders
					widget = {
						size = { 560 225 }

						### Purist Pattern
						background = {
							texture = "gfx/interface/colors/white.dds"
							color = { 0.38 0.15 0.15 1 }
							margin = { 0 12 }

							alpha = 0.5

							modify_texture = {
								texture = "gfx/interface/component_overlay/overlay_texture.dds"

								texture_density = 2
								spriteType = Corneredtiled

								alpha = 0.7
							}

							modify_texture = {
								texture = "gfx/interface/component_overlay/seamless_noise.dds"

								texture_density = 2
								spriteType = Corneredtiled

								alpha = 0.7
							}

							modify_texture = {
								texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
								blend_mode = alphaMultiply
							}

							using = Mask_Rough_Edges
						}

						### Loyalist Pattern
						background = {
							texture = "gfx/interface/colors/white.dds"
							color = { 0.1 0.16 0.25 1 }
							alpha = 0.5
							margin = { 0 12 }

							modify_texture = {
								texture = "gfx/interface/component_overlay/overlay_texture.dds"

								texture_density = 2
								spriteType = Corneredtiled

								alpha = 0.7
							}

							modify_texture = {
								texture = "gfx/interface/component_overlay/seamless_noise.dds"

								texture_density = 2
								spriteType = Corneredtiled

								alpha = 0.7
							}

							modify_texture = {
								texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
								blend_mode = alphaMultiply
								mirror = horizontal
							}

							modify_texture = {
								texture = "gfx/interface/component_masks/mask_scratches.dds"
								blend_mode = alphaMultiply
								alpha = 0.5
							}

							using = Mask_Rough_Edges
						}

						background = {
							texture = "gfx/interface/colors/black.dds"
							margin = { 0 12 }

							modify_texture = {
								texture = "gfx/interface/component_masks/mask_vignette.dds"
								blend_mode = alphaMultiply
								alpha = 0.8
							}

							using = Mask_Rough_Edges
						}

						group_banner = {
							parentanchor = left
							position = { 4 -10 }

							blockoverride "group_text" {
								text = "SITUATION_KIN_STRIFE_LOYALIST"
							}
							blockoverride "group_icon" {
								texture = "gfx/interface/icons/traits/kinstrife_loyalist.dds"
							}
							blockoverride "group_banner_texture" {
								texture = "gfx/interface/window_kin_strife/window_kin_strife_loyalist.dds"
								color = { 0.4 0.5 0.6 1}
							}
						}

						group_banner = {
							parentanchor = right
							position = { -4 -10 }

							blockoverride "group_text" {
								text = "SITUATION_KIN_STRIFE_PURIST"
							}
							blockoverride "group_icon" {
								texture = "gfx/interface/icons/traits/kinstrife_purist.dds"
							}
							blockoverride "group_banner_texture" {
								texture = "gfx/interface/window_kin_strife/window_kin_strife_purist.dds"
								color = { 0.65 0.55 0.4 1}
							}
						}


						widget = {
							size = { 50% 100% }
							datamodel = "[SituationParticipantGroup.GetCharacters]"
							datacontext = "[GetSituation('kin_strife').GetTopParticipantGroupByKey('loyalist_leader')]"

							item = {
								widget = {
									size = { 100% 100% }

									portrait_button = {
										size = { 180 280 }
										parentanchor = center
										position = { 40 0 }
										using = portrait_base

										blockoverride "portrait_transformation"
										{
											portrait_scale = {  1.0 1.0 }
											portrait_offset = { 0 0 }
										}

										portrait_texture = "[Character.GetAnimatedPortrait( 'environment_body', 'camera_body', 'chancellor', PdxGetWidgetScreenSize( PdxGuiWidget.Self ) )]"
										background_texture = "gfx/portraits/portrait_transparent.dds"
										effectname = "NoHighlight"
										texture = "gfx/portraits/portrait_transparent.dds"
										mask = "gfx/portraits/portrait_mask_body.dds"
									}

									widget = {
										size = { 100% 50 }
										parentanchor = bottom|hcenter

										allow_outside = yes

										hbox = {
											layoutpolicy_horizontal = expanding
											spacing = 12

											expand = {}

											widget = {
												allow_outside = yes
												size = { 50 0 }

												widget = {
													size = { 50 70 }
													position = { 0 -46 }
													allow_outside = yes

													vbox = {
														spacing = 8
														layoutpolicy_vertical = expanding
														portrait_opinion = {
															blockoverride "opinion_bg_alpha" {
																alpha = 0.6
															}
														}

														button_round = {
															visible = "[Not( ObjectsEqual( Character.Self, GetPlayer.Self ) )]"
															onclick = "[ToggleFilteredCharacterInteractionMenu(Character.Self, 'kin_strife')]"
															tooltip = "SITUATION_KIN_STRIFE_INTERACTION_BUTTON"

															button_icon = {
																alwaystransparent = yes
																parentanchor = center
																size = { 30 30 }
																texture = "gfx/interface/icons/flat_icons/character_interactions.dds"
															}

															text_single = {
																position = { 0 -8 }
																parentanchor = top|hcenter
																text = "[GetNumberOfValidInteractionsWithFilter(Character.Self, 'kin_strife')]"
																default_format = "#glow_color:{0.1,0.1,0.1,1.0}"

																background = {
																	margin = { 6 0 }
																	using = Background_Area_Dark
																}
															}
														}
													}
												}
											}

											widget = {
												allow_outside = yes
												size = { 34 20 }

												coa_realm_tiny_crown = {
													position = { 0 -24 }
													visible = "[Character.HasLandedTitles]"
												}
											}

											text_single = {
												text = "[Character.GetShortUINameNoTooltip]"
												default_format = "#glow_color:{0.1,0.1,0.1,1.0}"
												align = nobaseline

												background = {
													margin = { 12 4 }
													using = Mask_Rough_Edges
													using = Background_Area_Dark
												}
											}
											expand = {}
										}
									}
								}
							}
						}

						widget = {
							size = { 50% 100% }
							datamodel = "[SituationParticipantGroup.GetCharacters]"
							datacontext = "[GetSituation('kin_strife').GetTopParticipantGroupByKey('purist_leader')]"
							parentanchor = right
							position = { 0 0}

							item = {

								widget = {
									size = { 100% 100% }

									portrait_button = {
										size = { 180 280 }
										parentanchor = center
										position = { -40 0 }
										using = portrait_base

										blockoverride "portrait_transformation"
										{
											portrait_scale = {  1.0 1.0 }
											portrait_offset = { 0 0 }
										}

										portrait_texture = "[Character.GetAnimatedPortrait( 'environment_body', 'camera_body', 'disapproval', PdxGetWidgetScreenSize( PdxGuiWidget.Self ) )]"
										background_texture = "gfx/portraits/portrait_transparent.dds"
										effectname = "NoHighlight"
										texture = "gfx/portraits/portrait_transparent.dds"
										mask = "gfx/portraits/portrait_mask_body.dds"
									}

									widget = {
										size = { 100% 50 }
										parentanchor = bottom|hcenter

										allow_outside = yes

										hbox = {
											layoutpolicy_horizontal = expanding
											spacing = 12

											expand = {}

											text_single = {
												text = "[Character.GetShortUINameNoTooltip]"
												default_format = "#glow_color:{0.1,0.1,0.1,1.0}"
												align = nobaseline

												background = {
													margin = { 12 4 }
													using = Mask_Rough_Edges
													using = Background_Area_Dark
												}
											}


											widget = {
												allow_outside = yes
												size = { 34 20 }

												coa_realm_tiny_crown = {
													position = { 0 -24 }
													visible = "[Character.HasLandedTitles]"
												}
											}

											widget = {
												allow_outside = yes
												size = { 50 0 }

												widget = {
													size = { 50 70 }
													position = { 0 -46 }
													allow_outside = yes

													vbox = {
														spacing = 8
														layoutpolicy_vertical = expanding
														portrait_opinion = {
															blockoverride "opinion_bg_alpha" {
																alpha = 0.6
															}
														}

														button_round = {
															visible = "[Not( ObjectsEqual( Character.Self, GetPlayer.Self ) )]"
															onclick = "[ToggleFilteredCharacterInteractionMenu(Character.Self, 'kin_strife')]"
															tooltip = "SITUATION_KIN_STRIFE_INTERACTION_BUTTON"

															button_icon = {
																alwaystransparent = yes
																parentanchor = center
																size = { 30 30 }
																texture = "gfx/interface/icons/flat_icons/character_interactions.dds"
															}

															text_single = {
																position = { 0 -8 }
																parentanchor = top|hcenter
																text = "[GetNumberOfValidInteractionsWithFilter(Character.Self, 'kin_strife')]"
																default_format = "#glow_color:{0.1,0.1,0.1,1.0}"

																background = {
																	margin = { 6 0 }
																	using = Background_Area_Dark
																}
															}
														}
													}
												}
											}
											expand = {}
										}
									}
								}
							}
						}
					}

					widget = {
						allow_outside = yes
						widget = { # Current Phase area
							name = "current_phase_area"
							size = { 560 105 }
							position = { 0 -330 }

							# visible = "[Not( SituationWindow.GetSelectedFuturePhaseType.IsValid )]"

							### Banner Pattern
							background = {
								texture = "gfx/interface/window_struggle/point_based_phase_panel_interloper.dds"
							}

							### Purist Pattern
							background = {
								texture = "gfx/interface/window_struggle/point_based_phase_panel_interloper.dds"
								color = { 0.38 0.15 0.15 1 }

								alpha = 0.5

								modify_texture = {
									texture = "gfx/interface/component_overlay/overlay_texture.dds"

									texture_density = 2
									spriteType = Corneredtiled

									alpha = 0.7
								}

								modify_texture = {
									texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
									blend_mode = alphaMultiply
								}

								using = Mask_Rough_Edges
							}

							### Loyalist Pattern
							background = {
								texture = "gfx/interface/window_struggle/point_based_phase_panel_interloper.dds"
								color = { 0.1 0.16 0.25 1 }
								alpha = 0.5

								modify_texture = {
									texture = "gfx/interface/component_overlay/overlay_texture.dds"

									texture_density = 2
									spriteType = Corneredtiled

									alpha = 0.7
								}

								modify_texture = {
									texture = "gfx/interface/component_masks/mask_fade_horizontal.dds"
									blend_mode = alphaMultiply
									mirror = horizontal
								}

								modify_texture = {
									texture = "gfx/interface/component_masks/mask_scratches.dds"
									blend_mode = alphaMultiply
									alpha = 0.5
								}

								using = Mask_Rough_Edges
							}

							vbox = {
								name = "current_phase_widget"
								datacontext = "[SituationWindow.GetSelectedSubRegion.GetCurrentPhase]"
								datacontext = "[GetPlayer]"
								allow_outside = yes
								layoutpolicy_horizontal = expanding

								expand = {}

								hbox = {
									layoutpolicy_horizontal = expanding

									hbox = {
										name = "current_phase_header"
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										maximumsize = { 250 114 }
										margin_left = 25

										container = {
											name = "icon"

											icon = {
												size = { 74 74 }
												texture = "gfx/interface/icons/struggle_banners/icon_background_01.dds"
											}

											icon = {
												size = { 74 74 }
												texture = "[SituationSubRegion.GetCurrentPhase.GetType.GetIcon]"
											}
										}

										spacer = {
											size = { 5 10 }
										}

										vbox = {
											name = "text"
											layoutpolicy_horizontal = expanding
											minimumsize = { 170 1 }

											text_single = {
												layoutpolicy_horizontal = expanding
												text = "CURRENT_PHASE"
												max_width = 170
												margin_bottom = -8
												align = center
											}

											text_multi = {
												layoutpolicy_horizontal = expanding
												text = "[SituationWindow.GetSelectedSubRegion.GetCurrentPhase.GetType.GetName]"
												max_width = 140
												using = Font_Size_Medium
												default_format = "#high"
												autoresize = yes
												align = center
												margin = { 0 6  }
											}
										}
									}

									spacer = {
										size = { 45 10 }
									}

									vbox = {
										name = "current_phase_effects"
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										maximumsize = { 125 1 }
										margin_left = 35

										text_label_center = {
											text = "PHASE_EFFECTS_HEADER"
											default_format = "#high"
										}

										hbox = {
											name = "phase icons"
											layoutpolicy_vertical = expanding
											spacing = 6

											hbox = {
												layoutpolicy_horizontal = expanding

												fixedgridbox = {
													name = "named_effect_sets"
													layoutpolicy_horizontal = expanding

													addcolumn = 48
													addrow = 48
													setitemsizefromcell = yes
													datamodel_wrap = 6
													maxhorizontalslots = 6
													maxverticalslots = 2
													flipdirection = yes
													layoutanchor = topleft

													datamodel = "[SituationSubRegion.GetCurrentPhase.GetType.GetModifierNamedSets]"
													item = {
														button_phase_kin_strife_named_set_item = {}
													}
												}
											}
										}
									}
									expand = {}
								}

								expand = {}
							}
						}
					}

					widget = { # Progress bar showing faction strengths
						allow_outside = yes
						layoutpolicy_horizontal = expanding
						size = { 515 40 }

						progressbar_standard = { #Neutral
							parentanchor = center
							position = { 0 2 }
							size = { 80% 26 }

							blockoverride "progress_textures"
							{
								progresstexture = "gfx/interface/progressbars/progress_gray.dds"
								noprogresstexture = "gfx/interface/progressbars/progress_gray.dds"
							}

							value = "[EmptyScope.ScriptValue('lotr_kin_strife_total_loyalist_members')]"
							max = "[EmptyScope.ScriptValue('lotr_kin_strife_total_participants')]"
						}

						progressbar_standard = { #Purist
							parentanchor = center
							position = { 0 2 }
							size = { 80% 26 }
							mirror = horizontal

							blockoverride "progress_textures"
							{
								progresstexture = "gfx/interface/progressbars/progress_red.dds"
								noprogresstexture = "gfx/interface/progressbars/blank.dds"
							}

							value = "[EmptyScope.ScriptValue('lotr_kin_strife_total_loyalist_members')]"
							max = "[EmptyScope.ScriptValue('lotr_kin_strife_total_participants')]"
						}

						progressbar_standard = { #Loyalst
							parentanchor = center
							position = { 0 2 }
							size = { 80% 26 }

							blockoverride "progress_textures"
							{
								progresstexture = "gfx/interface/progressbars/progress_standard.dds"
								noprogresstexture = "gfx/interface/progressbars/blank.dds"
							}

							value = "[EmptyScope.ScriptValue('lotr_kin_strife_total_loyalist_members')]"
							max = "[EmptyScope.ScriptValue('lotr_kin_strife_total_participants')]"
						}
						
						kin_strife_group_percentages = { #Loyalist
							blockoverride "text" {
								raw_text = "#E [EmptyScope.ScriptValue('lotr_kin_strife_loyalist_score')]%#!"
							}
							blockoverride "tooltip" {
								tooltip = KIN_STRIFE_LOYALIST_SCORE
							}
						}

						kin_strife_group_percentages = { #Purist
							parentanchor = right
							blockoverride "text" {
								raw_text = "#color_red [EmptyScope.ScriptValue('lotr_kin_strife_purist_score')]%#!"
							}
							blockoverride "tooltip" {
								tooltip = KIN_STRIFE_PURIST_SCORE
							}
						}

						kin_strife_group_percentages = { #Neutral
							parentanchor = center
							blockoverride "text" {
								raw_text = "#color_gray [EmptyScope.ScriptValue('lotr_kin_strife_neutral_score')]%#!"
							}
							blockoverride "tooltip" {
								tooltip = KIN_STRIFE_NEUTRAL_SCORE
							}
						}

						divider = {
							parentanchor = center
							size = { 5 232 }
							position = { 0 -135 }
						}
					}
				}

				vbox = { # Participant Groups
					layoutpolicy_horizontal = expanding

					min_height = 75

					margin = { 15 15 }

					datacontext = "[SituationSubRegion.GetCharacterParticipantGroup( GetPlayer )]"

					background = {
						using = Background_Area_Solid
						alpha = 0.4
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding

						text_multi = {
							visible = "[Not( SituationParticipantGroup.IsValid )]"
							layoutpolicy_horizontal = expanding

							text = "SITUATION_WINDOW_NO_REGION_PARTICIPANT_GROUP"
							default_format = "#low"
							align = nobaseline
						}

						widget = {
							size = { 46 46 }

							icon = {
								framesize = { 100 100 }
								parentanchor = center
								texture = "gfx/interface/buttons/button_tab_round.dds"
								size = { 100% 100% }
								color = { 0.6 0.75 0.9 1 }
							}

							icon = {
								visible = "[SituationParticipantGroup.IsValid]"
								parentanchor = center
								size = { 80% 80% }
								texture = "[SituationParticipantGroup.GetType.GetIcon]"

								modify_texture = {
									texture = "gfx/interface/colors/colors_textured.dds"
									framesize = { 96 96 }
									frame = 7
								}
							}
						}

						vbox = {
							visible = "[SituationParticipantGroup.IsValid]"

							margin_left = 10
							text_single = {
								layoutpolicy_horizontal = expanding
								text = "[SituationParticipantGroup.GetName]"
								align = nobaseline
							}

							text_single = {
								layoutpolicy_horizontal = expanding

								text = "[SelectLocalization( Situation.HasMultipleSubRegions, 'SITUATION_WINDOW_YOUR_PARTICIPANT_GROUP_MULTI_SUBREGION', 'SITUATION_WINDOW_YOUR_PARTICIPANT_GROUP' ) ]"

								align = nobaseline
								default_format = "#Weak"
							}
						}

						expand = {}

						vbox = {
							spacing = 4

							button_standard_small = {
								onclick = "[SituationWindow.AccessParticipantCharacterList.Toggle]"
								text = "SITUATION_WINDOW_VIEW_PARTICIPANT_GROUPS"
							}

							button_standard_small = {
								text = "KIN_STRIFE_TOGGLE_CATALYSTS_WINDOW"
								visible = "[Not(GetVariableSystem.Exists( 'kin_strife_catalyst_window' ))]"
								onclick = "[GetVariableSystem.Set( 'kin_strife_catalyst_window', 'true' )]"
							}

							button_standard_small = {
								text = "KIN_STRIFE_TOGGLE_CATALYSTS_WINDOW"
								visible = "[GetVariableSystem.Exists( 'kin_strife_catalyst_window' )]"
								onclick = "[GetVariableSystem.Clear( 'kin_strife_catalyst_window' )]"
								down = "[GetVariableSystem.Exists( 'kin_strife_catalyst_window' )]"
							}
						}
					}
				}

				vbox = {
					layoutpolicy_horizontal = expanding
					datamodel = "[SituationPhase.GetFuturePhases]"

					item = {
						vbox = {
							layoutpolicy_horizontal = expanding
							min_height = 50

							hbox = {
								layoutpolicy_horizontal = expanding
								layoutpolicy_vertical = expanding
								margin = { 15 0 }

								expand = {}

								hbox = {
									layoutpolicy_horizontal = preferred
									layoutpolicy_vertical = expanding
									margin_right = 20

									widget = {
										size = { 510 30 }
										visible = "[FutureSituationPhase.HasPointsTakeoverType]"

										progressbar_standard = {
											text_single = {
												layoutpolicy_horizontal = expanding
												layoutpolicy_vertical = expanding

												margin_left = 10
												parentanchor = center|left

												text = "[FutureSituationPhase.GetType.GetName]"
												max_width = 230
												align = nobaseline
											}
		
											parentanchor = center
											size = { 510 30 }
											value = "[FutureSituationPhase.GetRelativeProgressPercent]"
											progresstexture = "gfx/interface/progressbars/progress_grandeur_increase.dds"
										}

										text_single = {
											parentanchor = center
											position = { 0 0 }
											text = "SITUATION_PHASE_POINT_TAKEOVER_VALUE"
										}
									}
								}

								text_single = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding

									visible = "[FutureSituationPhase.HasDurationTakeoverType]"

									autoresize = no

									text = "SITUATION_WINDOW_PHASE_TAKEOVER_DURATION"
									align = nobaseline|right
									margin_right = 10
								}
							}
						}
					}
				}

				hbox = {
					layoutpolicy_horizontal = expanding
					margin = { 12 8 }

					divider_light = {
						layoutpolicy_horizontal = expanding
					}

					spacer = {
